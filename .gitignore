# -*- mode: gitignore; -*-
# .gitignore для проекта Markoff 2.0
# Frontend: PySide6 (Qt for Python)
# Backend: FastAPI + SQLModel
# База данных: PostgreSQL (внешняя)

# ============================================
# Python - общее для backend и client
# ============================================

# Виртуальное окружение (если кто-то запускает локально, не в Docker)
venv/
env/
.env/
.venv/
ENV/
env.bak/
venv.bak/

# Кэши Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Дистрибутивы и сборки
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Файлы с локальными настройками (не путать с .env для Docker!)
*.local
*.orig

# IDE и редакторы
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# Backend (FastAPI)
# ============================================

# Локальные .env файлы (у нас конфиг через переменные окружения Docker)
# Но если кто-то запускает локально - пусть создаст свой .env.local
.env
!.env.example  # если создадим пример конфига
.env.local
.env.*.local

# Логи backend
logs/
*.log
backend/logs/

# Данные базы данных (если вдруг кто-то запустит SQLite для тестов)
*.db
*.sqlite3

# ============================================
# Client (PySide6)
# ============================================

# Локальные кэши Qt
client/.qtox
client/.qto-cache

# Настройки Qt Creator (если кто-то использует)
*.creator.user
*.creator.user.*

# ============================================
# Docker - временные артефакты
# ============================================

# Локальные Dockerfile для разработки (не путать с основными в /docker/)
Dockerfile.dev
Dockerfile.local
docker-compose.override.yml

# Временные файлы сборки
.dockerignore
!docker/.dockerignore  # но основной .dockerignore в папке docker не игнорируем

# ============================================
# Системные файлы Windows (ты работаешь на Windows)
# ============================================

# Windows thumbnail cache
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# Папка с историей и закладками проводника
[Dd]esktop.ini

# Файлы, создаваемые Windows Explorer
$RECYCLE.BIN/

# ============================================
# Файлы, которые НЕ нужно игнорировать (важные для проекта)
# ============================================

# НЕ игнорируем:
# - docker/ - там наши production Dockerfile
# - backend/src/ - исходники
# - client/src/ - исходники
# - docker-compose.yml - основной оркестратор
# - requirements.txt - зависимости